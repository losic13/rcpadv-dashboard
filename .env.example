# ============================================================
# Recipe Advisor Site Reliability Dashboard 설정 파일 (예시)
# 실제 사용 시 .env 로 복사 후 값 수정
# ============================================================

# ---- App ----
APP_HOST=0.0.0.0
APP_PORT=8000
QUERY_TIMEOUT_SECONDS=600

# ---- VNAND MariaDB ----
VNAND_DB_HOST=10.0.0.11
VNAND_DB_PORT=3306
VNAND_DB_USER=readonly
VNAND_DB_PASSWORD=changeme
VNAND_DB_NAME=vnand

# ---- DRAM MariaDB ----
DRAM_DB_HOST=10.0.0.12
DRAM_DB_PORT=3306
DRAM_DB_USER=readonly
DRAM_DB_PASSWORD=changeme
DRAM_DB_NAME=dram

# ---- Elasticsearch 8.15.1 ----
# 콤마로 여러 호스트 가능: http://es1:9200,http://es2:9200
ES_HOSTS=http://10.0.0.20:9200
ES_USERNAME=elastic
ES_PASSWORD=changeme
ES_VERIFY_CERTS=false

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_BUFFER_SIZE=500

# ---- Auth (단일 비밀번호 기반 로그인) ----
# 운영 환경에서는 반드시 두 값을 안전한 값으로 교체하세요.
APP_PASSWORD=changeme
SESSION_SECRET_KEY=dev-only-secret-please-override-in-env
SESSION_MAX_AGE=43200
SESSION_COOKIE_NAME=rcpadv_session

# ---- EQP I/F Manager (외부 페이지 임베드) ----
# 사이드바의 "EQP I/F Manager" 페이지에서 iframe 으로 로드할 URL.
# 사내 EQP I/F Manager 의 실제 주소로 변경하세요.
# 빈 값이면 페이지에 안내 메시지가 표시됩니다.
EQP_IF_MANAGER_URL=https://www.google.com
EQP_IF_MANAGER_TITLE=EQP I/F Manager
